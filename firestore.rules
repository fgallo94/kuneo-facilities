rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE UTILIDAD ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidIncidenceCreate() {
      let data = request.resource.data;
      return data.keys().hasAll([
        'title', 'category', 'propertyId', 'installationId', 'reportedBy',
        'description', 'imageUrls', 'status', 'severity', 'billTo', 'createdAt'
      ])
      && data.title is string && data.title.size() > 0 && data.title.size() <= 120
      && data.category is string && data.category.size() > 0
      && data.propertyId is string && data.propertyId.size() > 0
      && data.installationId is string && data.installationId.size() > 0
      && data.reportedBy is string && data.reportedBy == request.auth.uid
      && data.description is string && data.description.size() > 0
      && data.imageUrls is list
      && data.status is string && data.status == 'Backlog'
      && data.severity is int && data.severity >= 1 && data.severity <= 5
      && data.billTo is string && (data.billTo == 'Propietario' || data.billTo == 'Explotador')
      && data.createdAt is timestamp;
    }

    // --- COLECCIONES ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /groups/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /installations/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /properties/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /incidences/{incidenceId} {
      allow read: if isAdmin() || isOwner(resource.data.reportedBy);

      allow create: if isAuthenticated() && isValidIncidenceCreate();

      // Admin puede actualizar todo. El propietario solo puede añadir imageUrls tras la creación.
      allow update: if isAdmin() || (
        isOwner(resource.data.reportedBy)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['imageUrls'])
        && request.resource.data.imageUrls is list
      );

      allow delete: if false;

      match /history/{historyId} {
        allow read: if isAdmin() || isOwner(get(/databases/$(database)/documents/incidences/$(incidenceId)).data.reportedBy);
        allow create: if isAuthenticated()
          && request.resource.data.keys().hasAll(['changedBy', 'oldStatus', 'newStatus', 'timestamp'])
          && request.resource.data.changedBy == request.auth.uid
          && request.resource.data.timestamp is timestamp;
        allow update, delete: if false;
      }
    }
  }
}
