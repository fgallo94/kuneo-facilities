rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE UTILIDAD ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.keys().hasAny(['role']) && request.auth.token.role == 'admin')
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserWrite(uid) {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'assignedEntities'])
        && data.uid is string && data.uid == uid
        && data.email is string
        && data.displayName is string
        && data.role is string && (data.role == 'admin' || data.role == 'user')
        && data.assignedEntities is list;
    }

    function isValidIncidenceCreate() {
      let data = request.resource.data;
      return data.keys().hasAll([
        'title', 'category', 'propertyId', 'installationId', 'reportedBy',
        'description', 'imageUrls', 'status', 'severity', 'billTo', 'createdAt'
      ])
      && data.title is string && data.title.size() > 0 && data.title.size() <= 120
      && data.category is string && data.category.size() > 0
      && data.propertyId is string && data.propertyId.size() > 0
      && data.installationId is string && data.installationId.size() > 0
      && data.reportedBy is string && data.reportedBy == request.auth.uid
      && data.description is string && data.description.size() > 0
      && data.imageUrls is list
      && data.status is string && data.status == 'Reportada'
      && data.severity is int && data.severity >= 1 && data.severity <= 5
      && data.billTo is string && (data.billTo == 'Propietario' || data.billTo == 'Explotador')
      && data.createdAt is timestamp;
    }

    function isValidIncidenceUpdate() {
      let after = request.resource.data;
      let before = resource.data;
      let diffKeys = after.diff(before).affectedKeys();
      // Admin puede modificar status, assignedTo, severity, updatedAt e imageUrls
      return diffKeys.hasOnly(['imageUrls', 'status', 'severity', 'assignedTo', 'updatedAt', 'updatedBy']);
    }

    function isValidConformityUpdate() {
      let after = request.resource.data;
      let before = resource.data;
      let diffKeys = after.diff(before).affectedKeys();
      // El reportador puede modificar campos de conformidad cuando status es Reparado
      return before.status == 'Reparado'
        && diffKeys.hasOnly(['conformityStatus', 'conformityReason', 'conformityComment', 'conformityImageUrls', 'status', 'updatedAt', 'updatedBy']);
    }

    // --- COLECCIONES ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() && isValidUserWrite(userId);
      allow update: if isAdmin() || (
        isOwner(userId)
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmTokens'])
        )
      );
      allow delete: if isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /installations/{installationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /incidences/{incidenceId} {
      allow read: if isAdmin() || isOwner(resource.data.reportedBy);

      allow create: if isAuthenticated() && (isValidIncidenceCreate() || isAdmin());

      allow update: if isAdmin()
        || (
          isOwner(resource.data.reportedBy)
          && isValidIncidenceUpdate()
          && request.resource.data.imageUrls is list
        )
        || (
          isOwner(resource.data.reportedBy)
          && isValidConformityUpdate()
        );

      allow delete: if false;

      match /history/{historyId} {
        allow read: if isAdmin() || isOwner(get(/databases/$(database)/documents/incidences/$(incidenceId)).data.reportedBy);
        allow create: if isAuthenticated()
          && request.resource.data.keys().hasAll(['changedBy', 'changeType', 'timestamp'])
          && request.resource.data.changedBy == request.auth.uid
          && request.resource.data.changeType is string
          && request.resource.data.changeType in ['status', 'field', 'comment', 'creation', 'conformity']
          && request.resource.data.timestamp is timestamp
          && (
            request.resource.data.changeType != 'comment'
            || (request.resource.data.keys().hasAll(['comment']) && request.resource.data.comment is string)
          );
        allow update, delete: if false;
      }

      match /comments/{commentId} {
        allow read: if isAdmin() || isOwner(get(/databases/$(database)/documents/incidences/$(incidenceId)).data.reportedBy);
        allow create: if isAuthenticated()
          && request.resource.data.keys().hasAll(['authorId', 'text', 'createdAt'])
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.createdAt is timestamp
          && (
            request.resource.data.text.size() > 0
            || (request.resource.data.keys().hasAny(['imageUrl']) && request.resource.data.imageUrl is string)
          );
        allow update, delete: if false;
      }
    }

    match /counters/{counterId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /mail/{mailId} {
      allow read, write: if isAdmin();
    }

    match /userNotifications/{userId}/inbox/{notificationId} {
      allow read: if isOwner(userId);
      allow create: if isAdmin();
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['read', 'dismissed', 'dismissedAt', 'dismissedBy']);
      allow delete: if false;
    }
  }
}
