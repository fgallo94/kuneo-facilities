{
  "name": "kuneo-facilities",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/generate-fcm-sw.js",
    "dev": "next dev",
    "prebuild": "node scripts/generate-fcm-sw.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:integration": "npx firebase emulators:exec --project demo-project --only auth,functions,firestore \"vitest run --config vitest.integration.config.ts\"",
    "build:functions": "cd functions && npm run build",
    "kill:emulators": "node scripts/kill-emulators.js",
    "setup:cors": "echo Requiere gsutil. Ver INSTRUCCIONES_CORS.md o ejecuta: gsutil cors set cors.json gs://kuneo-facilities.firebasestorage.app",
    "type-check": "tsc --noEmit",
    "ci": "node scripts/ci.js"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@opentelemetry/api": "^1.9.1",
    "chart.js": "^4.5.1",
    "firebase": "^12.12.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
